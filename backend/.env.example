NODE_ENV=production
PORT=5000
API_PREFIX=/api/v1
FRONTEND_URL=https://your-frontend-domain.com

DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=ryven_webstore
DB_USER=postgres
DB_PASSWORD=change_me
DB_SSL=false

JWT_SECRET=replace_with_long_random_secret
JWT_EXPIRES_IN=14d

RAZORPAY_KEY_ID=rzp_live_xxxxx
RAZORPAY_KEY_SECRET=replace_me
RAZORPAY_WEBHOOK_SECRET=replace_me

# Leave 0 for free shipping; value is in paise (100 = ₹1)
SHIPPING_BASIC_PAISE=6000
SHIPPING_EXPRESS_PAISE=12000

# SMTP (e.g. Gmail, Brevo, Resend)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=your@gmail.com
SMTP_PASS=app_specific_password
SMTP_FROM="RYVEN <noreply@yourdomain.com>"

# Control panel (leave blank to disable)
CONTROL_ACTIONS_SECRET=
